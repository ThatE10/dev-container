# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
#
# cp .env.example .env

# ── SSH (provide at least one) ────────────────────────────────────────────────
SSH_PUBLIC_KEY=                    # e.g. $(cat ~/.ssh/id_rsa.pub)
SSH_PASSWORD=                      # alternative: plaintext password for root

# ── code-server (browser VS Code, port 8443) ─────────────────────────────────
# If set, the browser VS Code requires this password. If left blank, auth is
# disabled — only do that behind an SSH tunnel or on a trusted network.
CODE_SERVER_PASSWORD=

# ── HuggingFace ───────────────────────────────────────────────────────────────
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxx

# ── Anthropic ─────────────────────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxx

# ── Claude Code OAuth (for `claude` CLI inside the container) ─────────────────
# Extract from macOS Keychain after authenticating locally with `claude`:
#   security find-generic-password -s 'Claude Code-credentials' -w
CLAUDE_CREDENTIALS=

# ── Global Claude Code settings repo (synced into ~/.claude on start) ─────────
# The container clones this repo into ~/.claude and `git pull`s it every start,
# so your agents/hooks/skills/memory stay versioned and up to date. Your
# credentials and session state are gitignored by the repo and left untouched.
#   CLAUDE_SETTINGS_REPO   owner/repo or full git URL (blank = disable)
#   CLAUDE_SETTINGS_BRANCH branch to track (default: main)
#   CLAUDE_SETTINGS_SYNC   set to 0 to turn syncing off
CLAUDE_SETTINGS_REPO=ThatE10/claude-code-settings
CLAUDE_SETTINGS_BRANCH=main
CLAUDE_SETTINGS_SYNC=1

# ── Modal ─────────────────────────────────────────────────────────────────────
# https://modal.com/settings/tokens
MODAL_TOKEN_ID=ak-xxxx
MODAL_TOKEN_SECRET=as-xxxx

# ── GitHub ────────────────────────────────────────────────────────────────────
# https://github.com/settings/tokens  (needs: repo, read:org, workflow)
GITHUB_TOKEN=ghp_xxxx

# ── Optional: pull a .env from a private GitHub secrets repo ──────────────────
# The target repo must have a .env file at its root.
SECRETS_REPO=

# ── Weights & Biases ──────────────────────────────────────────────────────────
WANDB_API_KEY=
